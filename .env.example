# ============================================================
# 3D Filament Manager — 环境变量模板（公网 HTTPS 部署）
# ============================================================
# 使用方法：cp .env.example .env && 编辑下方变量
# 局域网 HTTP 部署请参考 .env.local.example
# ============================================================

# 访问密码（必填，请修改为你自己的密码）
APP_PASSWORD=changeme

# 站点地址（用于二维码跳转链接，修改为你的实际域名）
# 公网部署示例：https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# 数据库路径（Docker 部署无需修改）
DATABASE_URL=file:/app/data/spool_tracker.db

# Token 签名密钥（可选，不设置则使用 APP_PASSWORD）
# 建议公网部署时单独设置一个强密钥
# TOKEN_SECRET=

# 宿主机端口（默认 7743，Nginx 反代时通常无需修改）
# PORT=7743

# Cookie Secure 属性
# - 公网 HTTPS 部署：留空或设为 true（默认行为，Cookie 仅通过 HTTPS 传输）
# - 局域网 HTTP 部署：必须设为 false，否则登录后 Cookie 无法写入
# COOKIE_SECURE=true
