# 访问密码（必填，请修改为你自己的密码）
APP_PASSWORD=changeme

# 站点地址（二维码跳转链接，修改为你的实际地址）
NEXT_PUBLIC_BASE_URL=http://localhost:7743

# 数据库路径（Docker 部署无需修改）
DATABASE_URL=file:/app/data/spool_tracker.db

# 容器运行用户（可选，默认 1000:1000，建议设为宿主机当前用户的 UID:GID）
# 查看方法：在宿主机执行 id 命令，取 uid 和 gid 的值
# UID=1000
# GID=1000

# Token 签名密钥（可选，不设置则使用 APP_PASSWORD）
# TOKEN_SECRET=
