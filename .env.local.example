# ============================================================
# 3D Filament Manager — 环境变量模板（局域网 HTTP 部署）
# ============================================================
# 使用方法：cp .env.local.example .env && 编辑下方变量
# 公网 HTTPS 部署请参考 .env.example
# ============================================================

# 访问密码（必填，请修改为你自己的密码）
APP_PASSWORD=changeme

# 站点地址（用于二维码跳转链接）
# 请替换为你的局域网 IP，确保手机扫码后能访问到此地址
# 查看方法：
#   macOS:    ifconfig | grep "inet " | grep -v 127.0.0.1
#   Linux:    hostname -I | awk '{print $1}'
#   Windows:  ipconfig（查找 IPv4 地址）
#   NAS:      在 NAS 管理界面查看网络设置
NEXT_PUBLIC_BASE_URL=http://192.168.1.100:7743

# 数据库路径（Docker 部署无需修改）
DATABASE_URL=file:/app/data/spool_tracker.db

# Token 签名密钥（可选，不设置则使用 APP_PASSWORD）
# TOKEN_SECRET=

# 宿主机端口（默认 7743，可按需修改）
# PORT=7743

# Cookie Secure 属性
# ⚠️ 局域网 HTTP 部署必须设为 false，否则登录后 Cookie 无法写入
COOKIE_SECURE=false
